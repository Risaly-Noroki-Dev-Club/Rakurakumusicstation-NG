# Rakuraku Music Station - Rust 后端配置
# 复制为 config.toml 并根据需要修改。
# 环境变量（RADIO_* 前缀）可覆盖以下设置值。

[server]
# HTTP 监听地址
host = "0.0.0.0"
port = 2241

[database]
# SQLite（默认，无需外部依赖）
url = "sqlite://data/radio.db?mode=rwc"

[audio_engine]
# 媒体文件根目录
media_path = "./media"
# 音频流地址 — 支持三种模式：
#   "auto"          → 自动推断（推荐，根据请求 Host/X-Forwarded 头动态构建）
#   "/stream"       → 相对路径，由前端用 window.location 解析
#   "http://..."    → 强制绝对 URL（用于 CDN / 独立流服务器）
stream_base = "auto"

[device]
# Cookie 最大存活天数
cookie_max_age_days = 365
# 管理员设置令牌 — 在设备设置页输入此令牌以升级为管理员
# 首次使用前请修改为自定义值
admin_setup_token = "change-me-in-production"

[queue]
# 队列中最大歌曲数量
max_size = 100
# 限速窗口内每用户最大提交数
max_user_submissions = 3
# 限速窗口（秒）
rate_limit_window_secs = 300
# 点歌冷却时间（秒），0 表示禁用
request_cooldown_secs = 60

[station]
name = "Rakuraku Music Station"
subtitle = "A Community Radio Powered by Everyone"
primary_color = "#764ba2"
secondary_color = "#667eea"
bg_color = "#f4f4f9"

[logging]
level = "info"

[ncm]
# 网易云设备 ID（32 位小写 hex，首次启动时自动生成并持久化）
# 留空则每次启动生成新的 deviceId
device_id = ""
# 批量下载并发数（1 = 串行，最大 8）
download_concurrency = 1
